{
  "name": "gmail-ai-sorter",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "viltreon": "scripts/viltreon.mjs"
  },
  "scripts": {
    "dev": "prisma db push && node --max-old-space-size=6144 ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "prod": "prisma db push && set LOCAL_PROD_TEST=1 && next build && next start",
    "prod:deploy": "prisma migrate deploy && next build && next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "worker": "tsx src/worker.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "setup": "node scripts/setup.mjs",
    "viltreon": "node scripts/viltreon.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.1.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "bullmq": "^5.76.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "googleapis": "^144.0.0",
    "gsap": "^3.13.0",
    "ioredis": "^5.10.1",
    "lenis": "^1.1.14",
    "lucide-react": "^0.468.0",
    "motion": "^12.40.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.11",
    "p-limit": "^7.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "stripe": "^17.6.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.24.1"
  },
  "overrides": {
    "uuid": "^11.1.1",
    "qs": "^6.15.2",
    "protobufjs": "^7.5.8",
    "cookie": "^0.7.2",
    "postcss": "^8.5.10",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.60.0",
    "pm2": "^7.0.1",
    "postcss": "^8.5.10",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.0",
    "typescript": "^5.7.2"
  }
}
