generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  refresh_token_expires_in Int?
  session_state            String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id                       String    @id @default(cuid())
  email                    String    @unique
  emailVerified            DateTime?
  name                     String?
  image                    String?
  geminiKeyEnc             String?
  gmailHistoryId           String?
  autoSortEnabled          Boolean   @default(true)
  stripeCustomerId         String?   @unique
  stripeSubscriptionId     String?
  subscriptionStatus       String? // trialing | active | past_due | canceled | incomplete
  subscriptionEndsAt       DateTime?
  accessDisabled           Boolean   @default(false)
  emailsProcessedThisMonth Int       @default(0)
  emailMonthStartAt        DateTime?
  archiveSorted            Boolean   @default(false)
  sortScope                String    @default("unread")
  sortingRules             String?
  fallbackGmailLabelId     String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  labels      UserLabel[]
  sortingLogs SortingLog[]

  // Used by jobs/renew-watches.ts and worker.ts:setupPushWatches() to filter
  // the set of users eligible for live-sort wiring. At 5000+ users a full
  // scan is ~50ms; this turns it into an index lookup.
  @@index([autoSortEnabled, accessDisabled])
  // Used by Stripe webhook to find the User row given a subscription ID.
  // stripeSubscriptionId is rarely null and never updated after creation, so
  // a non-unique B-tree index is the right shape.
  @@index([stripeSubscriptionId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model UserLabel {
  id           String      @id @default(cuid())
  userId       String
  gmailLabelId String
  name         String
  type         String      @default("user")
  parentId     String?
  aiVisible    Boolean     @default(true)
  description  String?
  parent       UserLabel?  @relation("LabelParent", fields: [parentId], references: [id])
  children     UserLabel[] @relation("LabelParent")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gmailLabelId])
}

model ProcessedStripeEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model SortingLog {
  id           String    @id @default(cuid())
  userId       String
  labelApplied String
  confidence   Float
  modelUsed    String?
  processedAt  DateTime  @default(now())
  exportedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, processedAt])
  // Used by the daily export-logs job to find rows that haven't been
  // archived to GitHub yet. Without this it sequential-scans the entire
  // SortingLog table every night; at 5000 users / 30 days that's millions
  // of rows.
  @@index([exportedAt])
}
