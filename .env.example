# --- Authentication ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-via-openssl-rand-hex-32

# --- Google OAuth (create at https://console.cloud.google.com/apis/credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database (PostgreSQL via Neon — required) ---
DATABASE_URL=postgresql://CHANGE_ME
# Neon has a built-in connection pooler — no separate pgBouncer needed

# --- Encryption (32-byte hex key for encrypting Gemini keys + OAuth tokens) ---
# In production: ENCRYPTION_KEY is injected via systemd override (root-only), NOT in .env
ENCRYPTION_KEY=generate-via-openssl-rand-hex-32
ENCRYPTION_SALT=generate-via-openssl-rand-hex-32

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# --- Google Cloud Pub/Sub (for real-time email push) ---
GOOGLE_PROJECT_ID=email-sorter-494423
PUBSUB_TOPIC_NAME=projects/email-sorter-494423/topics/email-sorter-push
# Legacy shared-token auth — kept as fallback in dev.
PUBSUB_VERIFICATION_TOKEN=generate-via-openssl-rand-hex-32
# Preferred production auth (CASA tier 3). Set BOTH to enable OIDC.
# Audience must exactly match the push endpoint URL configured on the Pub/Sub
# subscription. Service account is the one used by --push-auth-service-account.
PUBSUB_OIDC_AUDIENCE=https://YOUR_DOMAIN/api/gmail/webhook
PUBSUB_OIDC_SERVICE_ACCOUNT=pubsub-push-invoker@YOUR_PROJECT.iam.gserviceaccount.com

# --- GitHub Export (daily sorting log archival to private repo) ---
GITHUB_TOKEN=
GITHUB_REPO=your-org/your-repo

# --- Redis (required for queue, rate limiting, JWT revocation, caching) ---
REDIS_URL=redis://localhost:6379
# In production: setup-vps.sh generates a random password and updates REDIS_URL
# REDIS_URL=redis://default:<password>@localhost:6379
REDIS_PREFIX=gmail-ai

# --- Error alerting (optional) ---
# If set, unhandled rejections / uncaught exceptions / worker crashes POST a
# short, PII-scrubbed summary here. Accepts a Slack or Discord incoming webhook
# URL. Leave blank to disable (no alerts, zero cost).
ALERT_WEBHOOK_URL=

# --- Bug report form (optional) ---
# Public URL of your hosted bug-report form (e.g. a Jotform share link). The
# dashboard "Report a bug" link opens this in a new tab. If unset, the link
# falls back to mailto:support@viltreon.com.
NEXT_PUBLIC_BUG_REPORT_URL=
