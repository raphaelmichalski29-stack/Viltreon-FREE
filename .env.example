# The setup wizard (`npm run setup`) generates all of this for you. This file is
# only a reference if you prefer to write .env by hand.

# --- Authentication ---
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=

# --- Google OAuth (create at https://console.cloud.google.com/apis/credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database (local SQLite file) ---
DATABASE_URL=file:./dev.db

# --- Encryption (encrypts the stored Groq key + OAuth tokens) ---
# Generate each with: openssl rand -hex 32
# BACK THESE UP — losing them makes stored Google tokens unrecoverable.
ENCRYPTION_KEY=
ENCRYPTION_SALT=

# --- Redis (optional) ---
# Leave blank to use the built-in in-memory queue (fine for a single-user,
# localhost install). Set a URL only if you want to use external Redis.
REDIS_URL=
REDIS_PREFIX=gmail-ai
